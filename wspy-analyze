    ),
}

# Files this tool never treats as the "counters" narrative text, even though
# they're .txt/.log -- tree output is a process hierarchy, not counter data,
# and launch.log/curation.json are launcher/studio bookkeeping.
EXCLUDED_TEXT_BASENAMES = {
    "process.tree.txt", "process.tree.summary.txt", "launch.log",
}


def load_template(path):
    with open(path, "r") as f:
        text = f.read()
    # Either template's own version marker (PERF_ANALYSIS_TEMPLATE_VERSION for
    # a single-run template, PERF_COMPARE_TEMPLATE_VERSION for a comparative
    # one) -- whichever is present identifies which kind of template this is,
    # so callers don't need to pass the marker name in themselves.
    m = re.search(r"^PERF_(?:ANALYSIS|COMPARE)_TEMPLATE_VERSION\s*=\s*(\S+)", text, re.MULTILINE)
    version = m.group(1) if m else "(unversioned)"
    return text, version


def find_run_manifest(rundir):
    """Returns the wspy-run unified-layout run-level manifest.json (parsed),
    or None if this doesn't look like that layout (e.g. a bare wspy run)."""
    path = os.path.join(rundir, "manifest.json")
    if not os.path.isfile(path):
        return None
    try:
        with open(path, "r") as f:
            data = json.load(f)
    except (OSError, ValueError):
        return None
    if not isinstance(data.get("passes"), list):
        return None
    return data


def collect_raw_text(rundir, run_manifest):
    """Returns (source_description, verbatim_text) for the human-readable
    counter output to feed the model. Prefers summary.txt (already the
    concatenation of every non-CSV, non-tree pass's output in a wspy-run
    layout), falling back to any standalone .txt files in the directory."""
    summary_path = os.path.join(rundir, "summary.txt")
    if os.path.isfile(summary_path) and os.path.getsize(summary_path) > 0:
        with open(summary_path, "r", errors="replace") as f:
            return "summary.txt", f.read()

    chunks = []
    for path in sorted(glob.glob(os.path.join(rundir, "*.txt"))):
        if os.path.basename(path) in EXCLUDED_TEXT_BASENAMES:
            continue
        with open(path, "r", errors="replace") as f:
            body = f.read()
        if body.strip():
            chunks.append("# %s\n%s" % (os.path.basename(path), body))
    if chunks:
        return "*.txt", "\n\n".join(chunks)
    return None, None


def collect_present_groups(rundir):
    """Scans every CSV's header row in rundir and resolves each column to a
    counter group via web/joblib.py's COLUMN_TO_GROUP, returning the set of
    resolved group names actually present in this run's data."""
    groups = set()
    for path in glob.glob(os.path.join(rundir, "*.csv")):
        try:
            with open(path, "r", errors="replace") as f:
                header = f.readline()
        except OSError:
            continue
        for column in header.strip().split(","):
            group = joblib.resolve_column_group(column.strip())
            if group:
                groups.add(group)
    return groups


def find_pass_manifest_paths(rundir, run_manifest):
    """Per-pass --manifest paths wspy-validate can check, resolved from the
    run-level manifest.json's passes[] entries when present, else any
    *.manifest.json file directly in rundir."""
    paths = []
    if run_manifest:
        for p in run_manifest.get("passes", []):
            mpath = p.get("manifest")
            if mpath:
                full = os.path.join(rundir, mpath) if not os.path.isabs(mpath) else mpath
                if os.path.isfile(full):
                    paths.append(full)
    if not paths:
        paths = sorted(glob.glob(os.path.join(rundir, "*.manifest.json")))
    return paths


def run_wspy_validate(validate_bin, manifest_paths, timeout):
    """Best-effort: returns wspy-validate's combined report text, or an
    explanatory placeholder if the binary is missing or no manifests were
    found -- degrade, don't fail, same idiom as coverage.c/wspy-plot's
    missing-gnuplot handling."""
    if not manifest_paths:
        return "(no per-pass manifest.json found in this run directory -- " \
               "wspy-validate was not run; pass --manifest when launching " \
               "wspy/wspy-run to enable this section)"
    if not os.path.isfile(validate_bin) or not os.access(validate_bin, os.X_OK):
        return "(wspy-validate binary not found at %s -- skipped; pass " \
               "--wspy-validate to point at it)" % validate_bin
    import subprocess
    try:
        proc = subprocess.run([validate_bin] + manifest_paths, capture_output=True,
                               text=True, timeout=timeout)
    except (OSError, subprocess.TimeoutExpired) as e:
        return "(wspy-validate failed to run: %s)" % e
    return (proc.stdout or "").strip() or "(wspy-validate produced no output)"


def group_notes_text(groups):
    if not groups:
        return "(no counter-group columns were resolved from this run's CSV headers)"
    return "\n".join("- %s" % GROUP_NOTES[g] for g in sorted(groups) if g in GROUP_NOTES)


def render_prompt(template_text, workload_text, validation_text, groups, raw_text):
    rendered = template_text
    rendered = rendered.replace("{{WORKLOAD}}", workload_text)
    rendered = rendered.replace("{{VALIDATION}}", validation_text)
    rendered = rendered.replace("{{COUNTER_GROUP_NOTES}}", group_notes_text(groups))
    rendered = rendered.replace("{{RAW_TEXT}}", raw_text)
    return rendered


def render_compare_prompt(template_text, data_a, data_b):
    """Design decision #8: one prompt covering two runs (data_a/data_b, each a
    gather_run_data() result) asking what changed and why, rather than
    analyzing either in isolation. Counter-group notes are the union of both
    runs' groups -- either run's columns are fair game for the model to
    reference."""
    rendered = template_text
    rendered = rendered.replace("{{WORKLOAD_A}}", data_a["workload_text"])
    rendered = rendered.replace("{{WORKLOAD_B}}", data_b["workload_text"])
    rendered = rendered.replace("{{VALIDATION_A}}", data_a["validation_text"])
    rendered = rendered.replace("{{VALIDATION_B}}", data_b["validation_text"])
    rendered = rendered.replace(
        "{{COUNTER_GROUP_NOTES}}", group_notes_text(data_a["groups"] | data_b["groups"]))
    rendered = rendered.replace("{{RAW_TEXT_A}}", data_a["raw_text"])
    rendered = rendered.replace("{{RAW_TEXT_B}}", data_b["raw_text"])
    return rendered


def workload_description(run_manifest, redact_command):
    if not run_manifest:
        return "(no run-level manifest.json found; command line unknown)"
    if redact_command:
        return "suite=%s benchmark=%s run_id=%s (command redacted via --redact-command)" % (
            run_manifest.get("suite", "?"), run_manifest.get("benchmark", "?"),
            run_manifest.get("run_id", "?"))
    command = run_manifest.get("command")
    command_text = " ".join(command) if isinstance(command, list) else str(command)
    return "suite=%s benchmark=%s run_id=%s\ncommand: %s" % (
        run_manifest.get("suite", "?"), run_manifest.get("benchmark", "?"),
        run_manifest.get("run_id", "?"), command_text)


def slugify(name):
    return re.sub(r"[^A-Za-z0-9._-]+", "_", name)


def run_dir_slug(rundir, run_manifest):
    """Identifies run B in comparative-mode output filenames -- its own
    suite/benchmark/run_id when a run-level manifest.json is present (the
    same identity workload_description() shows), else its directory
    basename, so two comparisons against different run B's never collide."""
    if run_manifest:
        parts = [p for p in (run_manifest.get("suite"), run_manifest.get("benchmark"),
                              run_manifest.get("run_id")) if p]
        if parts:
            return slugify("-".join(parts))
    return slugify(os.path.basename(os.path.normpath(rundir)))


def ollama_list_models(host, timeout):
    req = urllib.request.Request(host.rstrip("/") + "/api/tags")
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        data = json.load(resp)
    return [m["name"] for m in data.get("models", [])]


def ollama_generate(host, model, prompt, timeout):
    """stream: true (not Ollama's non-streaming default) is deliberate: with
    stream: false, Ollama computes the entire response server-side --
    including any hidden "thinking"/reasoning trace a model like deepseek-r1
    generates before its visible answer -- before writing a single HTTP
    body, so the client sees one continuous no-data gap from request to
    response. urlopen(timeout=N) applies per socket read, not per call, so
    that made `timeout` a hard cap on the *whole* generation rather than a
    stall detector -- confirmed against a real 36-model Ollama sweep, where
    several models that legitimately took 70-95s (already close to the
    120s default) succeeded while others (notably deepseek-r1:32b, a large
    reasoning model, vs. deepseek-r1:8b succeeding) timed out purely from
    generation length, not from being stuck. Streaming turns the same
    `timeout` into a per-chunk idle timeout instead: as long as some token
    arrives at least every `timeout` seconds, a slow-but-progressing
    generation of any length succeeds; a genuinely hung Ollama still times
    out promptly."""
    body = json.dumps({"model": model, "prompt": prompt, "stream": True}).encode("utf-8")
    req = urllib.request.Request(
        host.rstrip("/") + "/api/generate", data=body,
        headers={"Content-Type": "application/json"}, method="POST")
    chunks = []
    with urllib.request.urlopen(req, timeout=timeout) as resp:
        for line in resp:
            line = line.strip()
            if not line:
                continue
            obj = json.loads(line)
            chunks.append(obj.get("response", ""))
            if obj.get("done"):
                break
    return "".join(chunks)


CRITIQUE_SUFFIX = """

---
The above is the exact prompt you were just given, and here is your response to it:

%s
---

Setting aside the specific run data, critique the PROMPT itself (not your
answer): what about its structure, instructions, or included context could
be changed to get a more accurate, more useful performance analysis out of a
small local model like yourself? Be specific and concise (bullet points are
fine). Do not just restate your analysis.
"""


def analyze_one_model(host, model, prompt, timeout, critique, outdir,
                       analysis_prefix="aianalysis", critique_prefix="aiprompt.critique"):
    """Shared by single-run and comparative mode alike -- only the output
    filename prefixes differ (comparative mode namespaces them by run B's
    slug, see run_dir_slug()), the query/critique logic is identical either
    way."""
    slug = slugify(model)
    print("wspy-analyze: querying %s ..." % model, file=sys.stderr)
    t0 = time.time()
    try:
        response = ollama_generate(host, model, prompt, timeout)
    except (urllib.error.URLError, TimeoutError, OSError, ValueError) as e:
        # ValueError also catches json.JSONDecodeError -- a truncated/malformed
        # NDJSON line from ollama_generate()'s streamed read (e.g. the
        # connection dropped mid-chunk), same "skip this model, don't crash
        # the sweep" treatment as an outright connection failure.
        print("wspy-analyze: warning: %s: could not reach Ollama at %s: %s "
              "-- skipping" % (model, host, e), file=sys.stderr)
        return False
    elapsed = time.time() - t0
    out_path = os.path.join(outdir, "%s.%s.txt" % (analysis_prefix, slug))
    with open(out_path, "w") as f:
        f.write(response)
    print("wspy-analyze: %s -> %s (%.1fs, %d chars)" % (
        model, out_path, elapsed, len(response)), file=sys.stderr)

    if critique:
        critique_prompt = prompt + (CRITIQUE_SUFFIX % response)
        try:
            critique_text = ollama_generate(host, model, critique_prompt, timeout)
        except (urllib.error.URLError, TimeoutError, OSError, ValueError) as e:
            print("wspy-analyze: warning: %s: critique call failed: %s" % (model, e),
                  file=sys.stderr)
            return True
        critique_path = os.path.join(outdir, "%s.%s.txt" % (critique_prefix, slug))
        with open(critique_path, "w") as f:
            f.write(critique_text)
        print("wspy-analyze: %s critique -> %s" % (model, critique_path), file=sys.stderr)
    return True


def gather_run_data(rundir, validate_bin, redact_command, timeout, ap, label):
    """Everything render_prompt()/render_compare_prompt() needs for one run
    directory. Factored out so comparative mode can call this twice (once per
    run) and single-run mode once, without duplicating the collection logic."""
    run_manifest = find_run_manifest(rundir)
    source, raw_text = collect_raw_text(rundir, run_manifest)
    if raw_text is None:
        ap.error("no counter text output (summary.txt or *.txt) found under %r (%s)" %
                  (rundir, label))
    return {
        "rundir": rundir,
        "run_manifest": run_manifest,
        "source": source,
        "raw_text": raw_text,
        "groups": collect_present_groups(rundir),
        "validation_text": run_wspy_validate(
            validate_bin, find_pass_manifest_paths(rundir, run_manifest), timeout),
        "workload_text": workload_description(run_manifest, redact_command),
    }


def main():
    ap = argparse.ArgumentParser(
        description="Local-LLM (Ollama) narrative analysis of a wspy run directory's "
                    "already-computed/validated counter data.")
    ap.add_argument("--rundir", default=None,
                     help="run directory to analyze (wspy-run --suite/--benchmark layout, "
                          "or any directory holding a wspy manifest.json + text/CSV output); "
                          "run A when --compare-rundir is also given. Required unless "
                          "--list-models is given.")
    ap.add_argument("--compare-rundir", default=None,
                     help="second run directory (run B) -- switches to comparative mode: "
                          "asks the model what changed between --rundir (run A) and this "
                          "directory and why, instead of analyzing --rundir in isolation "
                          "(design decision #8 in the Ollama deep-dive)")
    ap.add_argument("--model", action="append", default=[],
                     help="Ollama model name to query (repeatable)")
    ap.add_argument("--all-models", action="store_true",
                     help="query every model 'ollama list' (via /api/tags) reports installed")
    ap.add_argument("--default-model", default=DEFAULT_MODEL_IF_PRESENT,
                     help="model to use when neither --model nor --all-models is given, "
                          "IF it's actually installed (default: %(default)s); if it isn't "
                          "installed, an explicit --model/--all-models is still required")
    ap.add_argument("--list-models", action="store_true",
                     help="print every model 'ollama list' (via /api/tags) reports installed, "
                          "one per line, and exit -- no --rundir needed. Lets a caller (e.g. "
                          "the web UI's model picker) discover model names without knowing "
                          "the Ollama API itself.")
    ap.add_argument("--ollama-host", default=DEFAULT_OLLAMA_HOST,
                     help="Ollama API base URL (default: %(default)s). Pointing this at a "
                          "non-default/remote host sends run data off this machine -- see "
                          "--redact-command.")
    ap.add_argument("--prompt-template", default=None,
                     help="prompt template file (default: prompts/perf_analysis.tmpl, or "
                          "prompts/perf_compare.tmpl when --compare-rundir is given)")
    ap.add_argument("--wspy-validate", default=os.path.join(SCRIPT_DIR, "wspy-validate"),
                     help="wspy-validate binary to run against this run's per-pass "
                          "manifests (default: %(default)s)")
    ap.add_argument("--redact-command", action="store_true",
                     help="omit the workload's literal command line from the prompt "
                          "(suite/benchmark/run_id are kept) -- recommended with a "
                          "non-default --ollama-host")
    ap.add_argument("--critique", action="store_true",
                     help="after each model's analysis, ask it to critique the prompt "
                          "template itself; writes aiprompt.critique.<model>.txt")
    ap.add_argument("--timeout", type=float, default=DEFAULT_TIMEOUT_SECONDS,
                     help="per-request timeout in seconds (default: %(default)s)")
    ap.add_argument("--dry-run", action="store_true",
                     help="render the prompt and print it, but don't call Ollama at all")
    args = ap.parse_args()

    if args.list_models:
        try:
            for name in ollama_list_models(args.ollama_host, args.timeout):
                print(name)
        except (urllib.error.URLError, TimeoutError, OSError) as e:
            print("wspy-analyze: error: --list-models could not reach Ollama at %s: %s" % (
                args.ollama_host, e), file=sys.stderr)
            return 1
        return 0

    if not args.rundir:
        ap.error("--rundir is required (unless --list-models is given)")
    rundir = os.path.abspath(args.rundir)
    if not os.path.isdir(rundir):
        ap.error("--rundir %r is not a directory" % args.rundir)

    compare_rundir = None
    if args.compare_rundir:
        compare_rundir = os.path.abspath(args.compare_rundir)
        if not os.path.isdir(compare_rundir):
            ap.error("--compare-rundir %r is not a directory" % args.compare_rundir)

    data_a = gather_run_data(rundir, args.wspy_validate, args.redact_command, args.timeout,
                              ap, "run A" if compare_rundir else "--rundir")

    template_path = args.prompt_template or (
        DEFAULT_COMPARE_TEMPLATE if compare_rundir else DEFAULT_TEMPLATE)
    template_text, template_version = load_template(template_path)

    if compare_rundir:
        data_b = gather_run_data(compare_rundir, args.wspy_validate, args.redact_command,
                                  args.timeout, ap, "run B")
        prompt = render_compare_prompt(template_text, data_a, data_b)
        slug_b = run_dir_slug(compare_rundir, data_b["run_manifest"])
        prompt_path = os.path.join(rundir, "aiprompt.compare.%s.txt" % slug_b)
        analysis_prefix = "aianalysis.compare.%s" % slug_b
        critique_prefix = "aiprompt.critique.compare.%s" % slug_b
        groups_desc = ",".join(sorted(data_a["groups"] | data_b["groups"])) or "(none)"
        log_line = ("wspy-analyze: comparative mode, template v%s, run A source=%s, "
                    "run B source=%s, groups=%s -> %s" % (
                        template_version, data_a["source"], data_b["source"],
                        groups_desc, prompt_path))
    else:
        prompt = render_prompt(template_text, data_a["workload_text"], data_a["validation_text"],
                                data_a["groups"], data_a["raw_text"])
        prompt_path = os.path.join(rundir, "aiprompt.txt")
        analysis_prefix = "aianalysis"
        critique_prefix = "aiprompt.critique"
        groups_desc = ",".join(sorted(data_a["groups"])) or "(none)"
        log_line = "wspy-analyze: template v%s, source=%s, groups=%s -> %s" % (
            template_version, data_a["source"], groups_desc, prompt_path)

    with open(prompt_path, "w") as f:
        f.write(prompt)
    print(log_line, file=sys.stderr)

    if args.dry_run:
        print(prompt)
        return 0

    models = list(args.model)
    if args.all_models:
        try:
            models.extend(m for m in ollama_list_models(args.ollama_host, args.timeout)
                           if m not in models)
        except (urllib.error.URLError, TimeoutError, OSError) as e:
            print("wspy-analyze: error: --all-models could not reach Ollama at %s: %s" % (
                args.ollama_host, e), file=sys.stderr)
            return 1
    elif not models and args.default_model:
        # Neither --model nor --all-models given: fall back to
        # --default-model, but only once confirmed installed -- never guess
        # silently, and never invent a model name Ollama doesn't actually
        # have. Any doubt (Ollama unreachable, model not installed) falls
        # through to the explicit-choice error below, same as today.
        try:
            installed = ollama_list_models(args.ollama_host, args.timeout)
        except (urllib.error.URLError, TimeoutError, OSError):
            installed = []
        if args.default_model in installed:
            models = [args.default_model]
            print("wspy-analyze: no --model given -- defaulting to %s (installed)" %
                  args.default_model, file=sys.stderr)
    if not models:
        ap.error("no model given -- pass --model NAME (repeatable) or --all-models "
                 "(default model %r is not installed)" % args.default_model)

    any_ok = False
    for model in models:
        if analyze_one_model(args.ollama_host, model, prompt, args.timeout,
                              args.critique, rundir, analysis_prefix, critique_prefix):
            any_ok = True
    return 0 if any_ok else 1


if __name__ == "__main__":
    sys.exit(main())

#!/usr/bin/env python3
"""
wspy-analyze -- local-LLM (Ollama) narrative analysis of wspy run artifacts
(INVESTIGATION_4.0.md's 4.4 priority list, "Local LLM (Ollama) narrative
analysis of run artifacts"; see that doc's "Local LLM (Ollama)
narrative-analysis deep-dive" for the full design this prototype follows).

Turns a run directory's already-computed, already-validated numbers into a
short prose explanation via a locally running Ollama model. Deliberately
narration over classification: every bottleneck category, PASS/WARN/FAIL
verdict, and coverage count fed into the prompt was computed by wspy/
wspy-validate before this tool ever runs, not derived by the model. The raw
counter text is always inlined into the prompt verbatim (never summarized by
this tool) so a reader can check any claim the model makes against the real
numbers.

Stdlib-only (matches wspy-queue/web/joblib.py's "thin client, no
dependency" convention) -- talks to Ollama's HTTP API directly
(POST /api/generate, GET /api/tags), no ollama Python package required.

Inputs (from a run directory produced by wspy-run's unified --suite/
--benchmark layout, or a bare wspy --manifest run):
  - summary.txt / <pass>.txt   the human-readable counter output ("counters.txt"
                                in the design discussion) -- fed to the model
                                verbatim, this tool never paraphrases it
  - manifest.json / <pass>.manifest.json
                                run identity + per-pass manifest paths, used to
                                run wspy-validate and to resolve which counter
                                groups are present
  - *.csv                      scanned only for their header row, to resolve
                                which counter groups are present via
                                web/joblib.py's existing COLUMN_TO_GROUP table
                                (reused, not reimplemented)

Outputs, written back into the same run directory:
  - aiprompt.txt                     the fully rendered prompt (template +
                                      this run's real data), so what was
                                      actually sent to the model is never a
                                      paraphrase a report could get wrong
  - aianalysis.<model-slug>.txt      the model's response
  - aiprompt.critique.<model-slug>.txt   (only with --critique) the model's
                                      own suggestions for improving the prompt
                                      template -- input for a human to fold
                                      into prompts/perf_analysis.tmpl by hand,
                                      never auto-applied

Comparative mode (--compare-rundir <dir>, design decision #8 in the deep-dive):
takes a second run directory (run B) alongside --rundir (run A) and asks the
model what changed between them and why, feeding both runs' raw counter text
and wspy-validate results into one prompt (prompts/perf_compare.tmpl) rather
than analyzing either run in isolation. Outputs are written into run A's
directory, namespaced by a slug identifying run B (its suite/benchmark/run_id
when available, else its directory basename) so they never collide with a
plain single-run analysis of run A:
  - aiprompt.compare.<run-b-slug>.txt
  - aianalysis.compare.<run-b-slug>.<model-slug>.txt
  - aiprompt.critique.compare.<run-b-slug>.<model-slug>.txt  (only with --critique)
"""
import argparse
import glob
import json
import os
import re
import sys
import time
import urllib.error
import urllib.request

SCRIPT_DIR = os.path.dirname(os.path.abspath(__file__))
sys.path.insert(0, os.path.join(SCRIPT_DIR, "web"))
import joblib  # noqa: E402 -- reuses COLUMN_TO_GROUP/resolve_column_group

DEFAULT_TEMPLATE = os.path.join(SCRIPT_DIR, "prompts", "perf_analysis.tmpl")
DEFAULT_COMPARE_TEMPLATE = os.path.join(SCRIPT_DIR, "prompts", "perf_compare.tmpl")
DEFAULT_OLLAMA_HOST = "http://localhost:11434"
DEFAULT_TIMEOUT_SECONDS = 120
# Applied only when neither --model nor --all-models is given, and only when
# this exact name is confirmed installed (ollama_list_models()) -- never a
# silent guess. Picked as a reasonable general-purpose default, not tuned
# against this codebase's own prompt; override with --default-model or just
# pass --model explicitly.
DEFAULT_MODEL_IF_PRESENT = "gpt-oss:20b"

# Short, model-facing explanations of what each counter group's columns mean.
# Keyed by the same ALL_GROUPS/"system" names web/joblib.py's
# resolve_column_group() already returns, so there is exactly one place that
# maps a CSV column to its counter-group meaning (COLUMN_TO_GROUP) and one
# place that maps a group to prose (this dict) -- neither is rederived here.
GROUP_NOTES = {
    "ipc": (
        "`ipc` is instructions-per-cycle: instructions retired divided by CPU "
        "cycles elapsed. Higher generally means more useful work per cycle, "
        "but the ceiling depends on the CPU's issue width -- there is no "
        "universal 'good' value to compare against."
    ),
    "topdown": (
        "`retire`/`frontend`/`backend`/`speculate` are a top-down pipeline-slot "
        "breakdown: the fraction of available execution slots spent retiring "
        "useful work, stalled on instruction fetch/decode, stalled on data/"
        "execution resources, or wasted on mis-speculated work. On AMD hosts "
        "there is a fifth line, `smt-contention`: slots lost to the *other* "
        "hardware thread sharing this physical core (SMT), not a stall type "
        "of this thread's own work -- do not skip it when it is present, and "
        "do not treat it as one of the four stall categories above. Each of "
        "the first four lines shows two percentages, e.g. \"27.7% (47.1%)\": "
        "the first is that category's share of ALL available slots "
        "(including whatever the other SMT thread used), and the "
        "parenthesized second number is its share of only this thread's own "
        "slots (excluding `smt-contention`). The first four percentages plus "
        "`smt-contention`'s own percentage should sum to roughly 100% of all "
        "slots; the four parenthesized percentages alone should sum to "
        "roughly 100% of this thread's own slots -- that second sum is what "
        "the `sanity check` line reports, so don't be confused if a quick "
        "sum of the first four numbers alone falls well short of 100%. "
        "`confidence`/`sanity` (when present) already flag low-confidence rows."
    ),
    "topdown-frontend": (
        "`icache`/`itlb1`/`itlb2`/`tlbflush` decompose frontend-bound time "

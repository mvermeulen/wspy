#!/usr/bin/env bash
#
# wspy-run - profile-driven launcher for wspy
#
# Collapses the repeated multi-pass wspy invocations historically hand-written in
# workload/*/run_test.sh (e.g. running the same command 7-8 times with different
# counter flag combinations to avoid multiplexing) into one reusable entry point.
# See INVESTIGATION.md, "Common workload wrapper / profile-driven launcher".
set -euo pipefail

SCRIPT_NAME=$(basename "$0")
SCRIPT_DIR=$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)

WSPY="${WSPY:-$SCRIPT_DIR/wspy}"
# Fixed staging path scripts/pts_hooks/{pre,post}_test_run.sh write to, if
# Phoronix Test Suite's result_notifier module hooks are registered on this
# host (scripts/setup_phoronix_hooks.sh) -- must match those scripts' own
# default exactly, since PTS invokes them with a replaced environment that
# can't carry this value down (see doc/phoronix_hook_investigation.md).
# run_pass() below relocates it into a per-pass artifact, so capture works
# regardless of which front end invoked wspy-run (workload/phoronix/
# run_test.sh, the web launcher's preset path, wspy-queue) rather than only
# the one caller that used to do this relocation itself.
WSPY_PTS_HOOK_LOG="${WSPY_PTS_HOOK_LOG:-/tmp/wspy_pts_hooks.log}"
OUTDIR="."
PREFIX=""
PROFILE=""
CONFIG_FILE=""
MANIFEST_DIR=""
RUN_INDEX=""
DRY_RUN=0
LIST_ONLY=0
WORKLOAD=()
SUITE=""
BENCHMARK=""
RUN_ID=""
UNIFIED=0
RUNROOT=""
AFFINITY=""
CONFIG_OPTIONS=()

declare -A PASS_EXT PASS_OUTFILE PASS_MANIFEST PASS_IS_TREE PASS_STATUS PASS_PTSLOG

BUILTIN_PROFILES=(quick deep-cpu deep-cpu-intel deep-gpu tree-heavy ibs-basic ibs-memory-deep gpu-compute zen-portable zen4plus-deep)

usage(){
  cat <<EOF
Usage: $SCRIPT_NAME [options] <profile> -- <command> [args...]
       $SCRIPT_NAME [options] -c <config-file> -- <command> [args...]
       $SCRIPT_NAME --list

Runs a sequence of predefined wspy passes ("a profile") against a single
workload command, collapsing the repeated multi-invocation wspy command
lines historically hand-written in workload/*/run_test.sh into one entry
point. Each pass is a separate wspy invocation with its own flag set,
writing to its own output file; where a profile's passes are just a sweep
of non-interval counter groups (e.g. deep-cpu/deep-gpu's CPU portion), one
pass instead uses wspy's own native multi-pass counter execution
(--passes=<list>) to cover several counter groups in a single wspy
invocation -- --interval passes (periodic ticks) still get their own
separate wspy invocation each, since --passes has no defined merge
semantics for those.

Builtin profiles:
  quick       one fast pass: ipc + system, human-readable output
  deep-cpu    systemtime/amdtopdown (--interval) plus one --passes sweep
              covering software/branch/ipc/topdown2/cache2/float/
              topdown-frontend/topdown-optlb, used for topdown
              characterization
  deep-cpu-intel  the Intel-only equivalent (software/branch, topdown, ipc/l2,
              backend) -- Intel doesn't have deep-cpu's AMD-specific opcache/
              frontend/l3 groups, so this is a separate, shorter sweep
  deep-gpu    deep-cpu plus GPU busy/metrics (--interval) passes (needs an
              AMDGPU=1 build to collect real data; passes still run
              otherwise since wspy itself just warns per pass and continues)
  tree-heavy  single --tree pass with full command-line capture, wrapped in a
              3600s timeout -- not because ptrace tracing itself is slower,
              but because an hour's worth of process-tree records is already
              more data than is practical to publish/browse; the counter
              passes' output stays small regardless of runtime, so those are
              left unbounded and allowed to run long if the workload does
              (see --list to check which passes in a given profile carry a
              timeout)
  ibs-basic   single pass: unfiltered AMD IBS (ibs_fetch+ibs_op) sample counts,
              one-second interval time series (AMD-only; wspy warns and
              produces no IBS columns elsewhere)
  ibs-memory-deep  single pass: AMD IBS with l3missonly+ldlat filtering on
              ibs_op for memory-path analysis, one-second interval time series
              -- known to skew the effective sampling period, see the run's
              own output for skew annotations
  gpu-compute single pass, one execution of the workload: process/syscall
              latency tracing (futex/io-wait/connect/wait/poll/nanosleep) +
              system CPU/load/network + package power + AMD sysfs GPU +
              NVIDIA NVML GPU + topdown, all on one --interval 1 time series
              -- for a GPU-bound/latency-driven workload (a renderer, a
              Vulkan compute host loop) where deep-gpu's separate per-category
              passes can't be correlated tick-for-tick against each other
  zen-portable     quick + ibs-basic composed (AMD, any Zen generation) --
              a fast, broadly-compatible default: quick's aggregate ipc/
              system summary plus a real AMD IBS interval time series,
              deliberately avoiding --power (RAPL/energy-pkg needs AMD
              Family 19h+, so Zen1/2 would just warn) and IBS l3missonly
              filtering (a Zen5-only hardware feature, see the Zen5/IBS
              deep-dive in INVESTIGATION.md) so it runs warning-free across
              the whole Zen family
  zen4plus-deep    deep-cpu + ibs-memory-deep composed (AMD Family 19h+,
              i.e. Zen4/Zen5) -- deep-cpu's full topdown/cache/branch sweep
              (already includes --power, real on Family 19h+) plus IBS with
              l3missonly+ldlat memory-path filtering, which needs a Zen5
              feature check to actually apply (Zen4 still runs this
              cleanly, just without l3missonly -- ibs.c degrades to
              unfiltered rather than failing, see the run's own skew
              annotations)

Options:
  -o, --outdir <dir>       Directory to write pass output files into (default: .;
                            root of the unified layout below when --suite/--benchmark
                            are given)
  -p, --prefix <name>      Prefix prepended to each pass's output filename (not
                            allowed together with --suite/--benchmark)
  -c, --config <file>      Load pass definitions from <file> instead of a builtin
                            profile (see "Config file format" below)
  --wspy <path>            Path to the wspy binary (default: \$WSPY or ./wspy next
                            to this script)
  --manifest-dir <dir>     Write a per-pass JSON manifest to
                            <dir>/<prefix><pass>.manifest.json (defaults to the run
                            directory itself when --suite/--benchmark are given)
  --run-index <file>       Append every pass's run-index record to <file> (shared
                            across passes; concurrent-safe via wspy's own flock)
  --suite <name>           Suite name, e.g. cpu2017/phoronix/pbbsbench -- enables
                            the unified output layout (see below); must be given
                            together with --benchmark
  --benchmark <name>       Benchmark/workload name, e.g. 503.bwaves_r, coremark --
                            must be given together with --suite
  --run-id <id>            Explicit run id for the unified layout (default: an
                            auto-generated, sortable <timestamp-ms>-<pid>); only
                            valid together with --suite/--benchmark
  --affinity <spec>        Pin every pass's workload to selected CPUs -- passed
                            through as-is to each wspy invocation's own
                            --affinity=<spec> (all/thread=<id>/nosmt/domain=<id>/
                            cpuset=<c0,c1,...>; run --wspy's own --list-affinity
                            to see this host's core/L3-domain ids)
  --config-option <k>=<v>  Metadata-only tag forwarded to every pass's own
                            --config-option <k>=<v> (repeatable) -- e.g. a
                            wspy-sweep cell's axis tag, or a uniform context
                            label (compiler/kernel/governor-as-observed);
                            recorded via wspy's structured configuration
                            provenance, queryable later via wspy-summary
                            --group-by-option <k>. Never affects what a pass
                            actually does.
  --list                   List builtin profiles and their passes, then exit
  --dry-run                Print the wspy command for each pass without running it
  -h, --help                Show this help

Unified output layout (INVESTIGATION.md, "Run artifact foundation"):
  Passing --suite and --benchmark switches from flat <outdir>/<prefix><pass>.<ext>
  output to a per-run directory tree, so publishing tools don't need suite-specific
  logic to find a run's files:

    <outdir>/<suite>/<benchmark>/<run-id>/
      <pass-name>.<csv|txt>       one file per pass, same content as flat mode
      <pass-name>.manifest.json   per-pass manifest (MANIFEST_DIR defaults here)
      process.tree.txt            written directly by a --tree pass (e.g. tree-heavy)
      summary.txt                 concatenation of every non-CSV, non-tree pass's
                                   output, generalizing the "cat *.txt > combined.txt"
                                   step workload/cpu2017 and workload/phoronix hand-roll
      manifest.json                run-level index: suite/benchmark/run_id plus each
                                   pass's output/manifest filename and wspy-level status
      <pass-name>.pts_hooks.log    Phoronix Test Suite result_notifier hook capture for
                                   this pass (scripts/pts_hooks/*.sh, doc/
                                   phoronix_hook_investigation.md) -- present only if
                                   the hooks are registered on this host
                                   (scripts/setup_phoronix_hooks.sh) and this pass's
                                   workload actually triggered them; absent otherwise
      plots/                       reserved, empty -- for a future report generator
                                   (4.1/4.2); nothing here populates it yet

  A profile argument may be a comma-separated list (e.g. "deep-cpu,tree-heavy") to
  run more than one builtin profile's passes in a single invocation -- this is how
  a suite that needs both a counter sweep and a --tree pass produces one unified
  run directory in one command. Pass names must be unique across the combined list.

Config file format:
  One pass per non-comment, non-blank line: "<pass-name> <wspy-flags...>".
  Lines beginning with # are comments. <wspy-flags...> is passed to wspy as-is
  (before the workload command); include --csv in a line if that pass should
  produce CSV output. Example:

    # deep-cpu-ish, without the GPU/tree passes
    software_branch --rusage --software --branch --no-ipc
    ipc_topdown      --ipc --topdown2 --no-rusage --no-software
    amdtopdown       --csv --interval 1 --topdown --no-rusage --no-software --no-ipc

Each pass's output is written to <outdir>/<prefix><pass-name>.<ext>, where
<ext> is "csv" if the pass's flags include --csv, else "txt".

Note: wspy's own exit status reflects whether wspy itself ran, not whether
the workload command succeeded (wspy always exits 0 once the child process
is launched, even if that child fails). This script's per-pass "done"/"wspy
error" reporting inherits that: it only catches wspy-level failures. Use
--manifest-dir or --run-index and inspect exit_status there to check whether
the workload command itself succeeded.

Examples:
  $SCRIPT_NAME --list
  $SCRIPT_NAME -o results/coremark quick -- phoronix-test-suite batch-run coremark
  $SCRIPT_NAME -o results/503.bwaves --run-index results/index.jsonl deep-cpu -- \\
      runcpu --config mev-aocc.cfg --action=validate --tune base 503.bwaves_r
  $SCRIPT_NAME --dry-run -c my-passes.conf -- sleep 1
EOF
}

declare -a PASS_NAMES
declare -a PASS_FLAGS
declare -a PASS_TIMEOUTS

load_builtin_profile(){
  local profile="$1"
  PASS_TIMEOUTS=()
  case "$profile" in
    quick)
      PASS_NAMES=(run)
      PASS_FLAGS=("--ipc --system --rusage")
      ;;
    deep-cpu)
      # The five non-interval counter passes this profile used to run as
      # five separate wspy invocations (software_branch, ipc_topdown,
      # l2_float, frontend, opcache) now collapse onto one native --passes
      # invocation (wspy.c's run_multipass(), INVESTIGATION.md's 4.1
      # Tier 1 "Native multi-pass counter execution" item) -- wspy itself
      # bin-packs them into however many hardware-PMU-fitting sub-passes are
      # needed and merges the result into one CSV/manifest record, instead
      # of wspy-run gluing five separate output files together after the
      # fact. systemtime/amdtopdown stay separate: --passes has no defined
      # merge semantics for --interval's periodic ticks (each pass is a
      # separately-timed re-execution of the workload), so those two keep
      # their own wspy invocation same as before. No --csv here (matching
      # the five passes it replaces) -- human-readable output still flows
      # into summary.txt alongside systemtime/amdtopdown's own output.
      # cache3 (L3 hit/miss) and memory (local/remote data-cache-refill
      # locality) were audited in and added here: cache3 uses AMD's L3
      # uncore PMU budget (excluded from preflight's general-purpose slot
      # count, so it's effectively free); memory's raw events carry their
      # own requires=/sys/devices/system/node/node1 gate (topdown.c) so on
      # a single-NUMA-node host (most client/APU parts) the group is a real
      # zero-cost skip rather than a pass spent measuring a number that can
      # only ever read as "100% local". --power rides along on systemtime
      # (not the --passes sweep, which fatals against --power -- it's a
      # separate system-wide RAPL PMU with no multi-pass merge semantics,
      # same reasoning as IBS) rather than amdtopdown: systemtime already
      # opens zero hardware counters, so --power is a genuinely free
      # addition there, and it lands pkg_watts/pkg_joules in the same CSV
      # as cpu/freq -- exactly what wspy-plot's power-vs-utilization/
      # power-vs-frequency dual-axis templates pair it against.
      PASS_NAMES=(systemtime counters amdtopdown)
      PASS_FLAGS=(
        "--csv --interval 1 --no-rusage --no-software --system --no-ipc --power"
        "--passes=software,branch,ipc,topdown2,cache2,cache3,memory,float,topdown-frontend,topdown-optlb"
        "--csv --interval 1 --topdown --no-rusage --no-software --no-ipc"
      )
      ;;
    deep-cpu-intel)
      PASS_NAMES=(software_branch topdown ipc_l2 backend)
      PASS_FLAGS=(
        "--rusage --software --branch --no-ipc"
        "--topdown2 --no-rusage --no-software --no-ipc"
        "--ipc --cache2 --no-rusage --no-software"
        "--no-ipc --no-rusage --topdown-backend"
      )
      ;;
    deep-gpu)
      # deep-cpu's CPU sweep, collapsed onto --passes the same way -- see the
      # comment there -- plus the two GPU interval passes, which (like
      # systemtime/amdtopdown) stay their own wspy invocation since --passes
      # doesn't cover --interval. systemtime carries --power for the same
      # reason deep-cpu's does (see that profile's own comment): it already
      # opens zero hardware counters, so --power is a free addition there,
      # landing pkg_watts/pkg_joules in the same CSV as cpu/freq for
      # wspy-plot's power-vs-utilization/power-vs-frequency templates --
      # this was a pre-existing asymmetry between the two profiles, not a
      # deliberate omission (INVESTIGATION.md's "4.2 -- remaining work").
      PASS_NAMES=(systemtime counters amdtopdown gpu_busy gpu_metrics)
      PASS_FLAGS=(
        "--csv --interval 1 --no-rusage --no-software --system --no-ipc --power"
        "--passes=software,branch,ipc,topdown2,cache2,cache3,memory,float,topdown-frontend,topdown-optlb"
        "--csv --interval 1 --topdown --no-rusage --no-software --no-ipc"
        "--csv --interval 1 --gpu-busy --no-ipc --no-rusage --no-software"
        "--csv --interval 1 --gpu-metrics --no-ipc --no-rusage --no-software"
      )
      ;;
    tree-heavy)
      PASS_NAMES=(tree)
      PASS_FLAGS=("--tree ${OUTDIR}/${PREFIX}process.tree.txt --tree-cmdline --software --no-ipc")
      # workload/*/run_test.sh used to wrap only this one $WSPY invocation in
      # `timeout 3600`, never the others -- not because ptrace tracing runs
      # slower, but because an hour's worth of process-tree records is
      # already more data than is practical to publish/browse, so there's no
      # value in letting it run longer. The counter passes' output stays
      # small regardless of runtime, so they were (and still are here) left
      # unbounded -- a slow workload is fine to just wait out for those.
      # TODO: this fixed 3600s is a blunt stand-in for an actual estimate;
      # e.g. phoronix-test-suite has a run-time estimate command that could
      # size this per-workload instead (see INVESTIGATION.md).
      PASS_TIMEOUTS=(3600)
      ;;
    ibs-basic)
      PASS_NAMES=(ibs)
      PASS_FLAGS=("--csv --interval 1 --ibs-basic --no-ipc")
      ;;
    ibs-memory-deep)
      PASS_NAMES=(ibs)
      PASS_FLAGS=("--csv --interval 1 --ibs-memory-deep --no-ipc")
      ;;
    gpu-compute)
      # For a GPU-bound/latency-driven workload (a game renderer, a Vulkan
      # compute kernel host loop like ollama's) the deep-cpu/deep-gpu shape
      # of "one wspy invocation per instrumentation category" is actively
      # misleading: each category re-executes the whole workload separately,
      # so a game's Vulkan-then-software-render phase split (or a model's
      # prompt-processing-then-decode phase split) lands at different
      # wall-clock offsets in each category's own CSV, and can't be
      # correlated tick-for-tick. This profile instead runs everything in
      # ONE wspy invocation/one execution of the workload: process/syscall
      # latency tracing (futex/io-wait/connect/wait/poll/nanosleep -- the
      # same subset the web launcher's checklist already found useful for a
      # host thread that mostly blocks on GPU completion rather than
      # computing), system-wide CPU/load/network, package power, both GPU
      # backends (AMD sysfs busy/temp/activity/power/freq + NVIDIA NVML
      # busy/VRAM -- harmless no-ops if a build/host lacks one), and topdown
      # to confirm (or rule out) the host CPU itself as a bottleneck -- all
      # on one --interval 1 time series so every column lines up against
      # the same clock. Needs an AMDGPU=1/NVIDIA=1 build to get real GPU
      # data; wspy itself just warns and continues otherwise.
      PASS_NAMES=(gpu_compute)
      PASS_FLAGS=(
        "--tree ${OUTDIR}/${PREFIX}process.tree.txt --tree-futex --tree-io-wait --tree-connect --tree-wait --tree-poll --tree-nanosleep --system --power --gpu-busy --gpu-metrics --gpu-nvidia --topdown --no-ipc --interval 1 --csv"
      )
      ;;
    zen-portable)
      # Composed from two already-tested profiles (INVESTIGATION.md's 4.2
      # Tier 1, "Zen-family preset packs" item) rather than duplicating
      # their flag strings by hand -- load_profiles() (below) already does
      # exactly this concatenation for a user-supplied comma list, so this
      # just calls it with a fixed spec instead of inventing a second
      # composition mechanism. See usage() above for the "why these two,
      # why not --power/l3missonly" rationale.
      load_profiles "quick,ibs-basic"
      return
      ;;
    zen4plus-deep)
      load_profiles "deep-cpu,ibs-memory-deep"
      return
      ;;
    *)
      echo "$SCRIPT_NAME: unknown profile: $profile (try --list)" >&2
      exit 1
      ;;
  esac
  # Pad PASS_TIMEOUTS to PASS_NAMES' length for profiles above that didn't set
  # per-pass timeouts (i.e. all of them except tree-heavy) -- "" means no timeout.
  local i
  for ((i=${#PASS_TIMEOUTS[@]}; i<${#PASS_NAMES[@]}; i++)); do
    PASS_TIMEOUTS[i]=""
  done
}

load_config_file(){
  local file="$1"
  if [ ! -r "$file" ]; then
    echo "$SCRIPT_NAME: cannot read config file: $file" >&2
    exit 1
  fi
  PASS_NAMES=()
  PASS_FLAGS=()
  PASS_TIMEOUTS=()
  local line name flags
  while IFS= read -r line || [ -n "$line" ]; do
    line="${line#"${line%%[![:space:]]*}"}"
    line="${line%"${line##*[![:space:]]}"}"
    [ -z "$line" ] && continue
    case "$line" in
      \#*) continue ;;
    esac
    name="${line%% *}"
    flags="${line#* }"
    if [ "$name" = "$line" ]; then
      echo "$SCRIPT_NAME: config line missing flags: $line" >&2
      exit 1
    fi
    PASS_NAMES+=("$name")
    PASS_FLAGS+=("$flags")
    PASS_TIMEOUTS+=("")
  done < "$file"
  if [ ${#PASS_NAMES[@]} -eq 0 ]; then
    echo "$SCRIPT_NAME: config file has no passes: $file" >&2
    exit 1
  fi
}

# Loads one or more comma-separated builtin profiles into PASS_NAMES/PASS_FLAGS,
# concatenated in list order. A single profile name works exactly as before;
# the comma form (e.g. "deep-cpu,tree-heavy") is how a suite that needs both a
# counter sweep and a --tree pass produces one run directory in one invocation.
load_profiles(){
  local spec="$1"
  local -a subprofiles all_names=() all_flags=() all_timeouts=()
  IFS=',' read -r -a subprofiles <<< "$spec"
  local p i
  for p in "${subprofiles[@]}"; do
    load_builtin_profile "$p"
    for i in "${!PASS_NAMES[@]}"; do
      all_names+=("${PASS_NAMES[$i]}")
      all_flags+=("${PASS_FLAGS[$i]}")
      all_timeouts+=("${PASS_TIMEOUTS[$i]}")
    done
  done
  PASS_NAMES=("${all_names[@]}")
  PASS_FLAGS=("${all_flags[@]}")
  PASS_TIMEOUTS=("${all_timeouts[@]}")
  local seen=" " n
  for n in "${PASS_NAMES[@]}"; do
    case "$seen" in
      *" $n "*)
        echo "$SCRIPT_NAME: duplicate pass name '$n' across combined profiles: $spec" >&2
        exit 1 ;;
    esac
    seen="$seen$n "
  done
}

list_profiles(){
  local p i suffix
  for p in "${BUILTIN_PROFILES[@]}"; do
    load_builtin_profile "$p"
    echo "$p:"
    for i in "${!PASS_NAMES[@]}"; do
      suffix=""
      [ -n "${PASS_TIMEOUTS[$i]}" ] && suffix="  [timeout ${PASS_TIMEOUTS[$i]}s]"
      printf '  %-16s %s%s\n' "${PASS_NAMES[$i]}" "${PASS_FLAGS[$i]}" "$suffix"
    done
    echo
  done
}

run_pass(){
  local name="$1" flags="$2" timeout_secs="${3:-}"
  local ext="txt"
  case " $flags " in
    *" --csv "*) ext="csv" ;;
  esac
  local outfile="${OUTDIR}/${PREFIX}${name}.${ext}"
  local manifest_file=""
  local -a flagarr
  read -r -a flagarr <<< "$flags"
  local -a cmd=()
  if [ -n "$timeout_secs" ]; then
    cmd+=(timeout "$timeout_secs")
  fi
  cmd+=("$WSPY" "${flagarr[@]}" -o "$outfile")
  if [ -n "$AFFINITY" ]; then
    cmd+=(--affinity "$AFFINITY")
  fi
  # --config-option (repeatable, top-level, INVESTIGATION.md's "Comparison
  # matrix mode deep-dive", piece 2): unlike --preset-name/--config-name
  # below (this script's own vocabulary, always auto-emitted), these are
  # caller-supplied metadata -- a wspy-sweep cell's own axis tag, or a
  # human's uniform context label (compiler/kernel/governor-as-observed) --
  # forwarded through unchanged to every pass exactly like --affinity
  # already is, not derived from anything this script knows about.
  for opt in "${CONFIG_OPTIONS[@]+"${CONFIG_OPTIONS[@]}"}"; do
    cmd+=(--config-option "$opt")
  done
  if [ -n "$MANIFEST_DIR" ]; then
    manifest_file="${MANIFEST_DIR}/${PREFIX}${name}.manifest.json"
    cmd+=(--manifest "$manifest_file")
  fi
  if [ -n "$RUN_INDEX" ]; then
    cmd+=(--run-index "$RUN_INDEX")
  fi
  # Structured configuration provenance (INVESTIGATION.md item 16): wspy
  # itself has no notion of presets/configurations, so wspy-run -- the front
  # end that does -- passes its own vocabulary through as metadata. PROFILE is
  # only set for a named builtin profile (comma-composed lists included
  # verbatim, e.g. "deep-cpu,tree-heavy"), not for a -c/--config pass-list
  # file, since that path has no named preset to record. name (this pass's
  # own PASS_NAMES entry, e.g. "amdtopdown") is always recorded as the
  # configuration -- it's the one piece of launcher vocabulary every pass has,
  # preset or not.
  if [ -n "$PROFILE" ]; then
    cmd+=(--preset-name "$PROFILE")
  fi
  cmd+=(--config-name "$name")
  cmd+=(-- "${WORKLOAD[@]}")

  PASS_EXT["$name"]="$ext"
  PASS_OUTFILE["$name"]="$outfile"
  PASS_MANIFEST["$name"]="$manifest_file"
  PASS_PTSLOG["$name"]=""
  case " $flags " in
    *" --tree "*) PASS_IS_TREE["$name"]=1 ;;
    *) PASS_IS_TREE["$name"]=0 ;;
  esac

  if [ "$DRY_RUN" -eq 1 ]; then
    printf '[%s] ' "$name"
    printf '%q ' "${cmd[@]}"
    echo
    return 0
  fi

  # A non-empty staging log at this point predates this pass: either an
  # earlier pass in this same wspy-run invocation (each pass fully
  # re-executes the workload, so PTS's result_notifier hooks -- if
  # registered, scripts/setup_phoronix_hooks.sh -- fire again every time) or
  # a stale leftover from an interrupted earlier run that never reached the
  # relocation step below. Either way it must not be attributed to this
  # pass -- move it aside rather than lose or misattribute it.
  if [ -s "$WSPY_PTS_HOOK_LOG" ]; then
    mv "$WSPY_PTS_HOOK_LOG" "${WSPY_PTS_HOOK_LOG}.stale-$$"
    echo "[$name] found a stale $WSPY_PTS_HOOK_LOG predating this pass, moved aside to ${WSPY_PTS_HOOK_LOG}.stale-$$" >&2
  fi

  echo "[$name] ${cmd[*]}" >&2
  # Note: wspy's own exit status reflects whether wspy itself ran (it always
  # returns 0 once the child is launched, even if the child command fails or
  # is not found -- see wspy.c main()). "done"/"wspy error" below therefore
  # only catch wspy-level failures (bad options, can't open output file,
  # fork failure, ...), not workload command failures; check --manifest or
  # --run-index exit_status for that.
  local ok=1
  if "${cmd[@]}"; then
    echo "[$name] done -> $outfile" >&2
    PASS_STATUS["$name"]="ok"
  else
    local rc=$?
    echo "[$name] wspy error (exit $rc) -> $outfile" >&2
    PASS_STATUS["$name"]="wspy-error"
    ok=0
  fi

  # Relocate this pass's own PTS hook capture (if the hooks are registered
  # on this host and this pass's workload actually triggered them) into a
  # per-pass artifact next to its output/manifest -- captured here, in the
  # one place every profile's passes funnel through, rather than by whatever
  # front end happened to invoke wspy-run. By now the workload command (and
  # every hook subprocess PTS spawned) has fully exited, so this isn't a
  # race against anything still writing. Silently a no-op if the hooks
  # aren't registered or this pass's workload wasn't a PTS invocation --
  # same measured-vs-unavailable idiom used throughout this codebase.
  if [ -s "$WSPY_PTS_HOOK_LOG" ]; then
    local ptslog_file="${OUTDIR}/${PREFIX}${name}.pts_hooks.log"
    mv "$WSPY_PTS_HOOK_LOG" "$ptslog_file"
    PASS_PTSLOG["$name"]="$ptslog_file"
    echo "[$name] pts hooks captured -> $ptslog_file" >&2
  fi

  [ "$ok" -eq 1 ]
}

json_escape(){
  local s="$1"
  s="${s//\\/\\\\}"
  s="${s//\"/\\\"}"
  printf '%s' "$s"
}

# Concatenates every non-CSV, non-tree pass's output into summary.txt,
# generalizing the "cat software.branch.txt ipc.topdown.txt ... > combined.txt"
# step workload/cpu2017 and workload/phoronix hand-roll today.
generate_summary(){
  local out="${RUNROOT}/summary.txt"
  local tmp="${out}.tmp"
  local name wrote=0
  : > "$tmp"
  for name in "${PASS_NAMES[@]}"; do
    [ "${PASS_EXT[$name]}" = "txt" ] || continue
    [ "${PASS_IS_TREE[$name]}" = "1" ] && continue
    {
      printf '=== %s ===\n' "$name"
      cat "${PASS_OUTFILE[$name]}" 2>/dev/null
      printf '\n'
    } >> "$tmp"
    wrote=1
  done
  if [ "$wrote" -eq 1 ]; then
    mv "$tmp" "$out"
  else
    rm -f "$tmp"
  fi
}

# Run-level index: not a per-process wspy manifest (see manifest.h/manifest.c --
# each pass already writes its own via --manifest), but the thing that ties
# suite/benchmark/run_id to the set of passes that ran and where their files
# and per-pass manifests landed, so a reader doesn't need suite-specific logic.
generate_manifest(){
  local out="${RUNROOT}/manifest.json"
  local generated_at
  generated_at=$(date -u +%Y-%m-%dT%H:%M:%S.000Z)
  {
    printf '{\n'
    printf '  "layout_version": "1.0.0",\n'
    printf '  "suite": "%s",\n' "$(json_escape "$SUITE")"
    printf '  "benchmark": "%s",\n' "$(json_escape "$BENCHMARK")"
    printf '  "run_id": "%s",\n' "$(json_escape "$RUN_ID")"
    printf '  "generated_at": "%s",\n' "$generated_at"
    printf '  "command": ['
    local first=1 w
    for w in "${WORKLOAD[@]}"; do
      [ "$first" -eq 1 ] || printf ', '
      printf '"%s"' "$(json_escape "$w")"
      first=0
    done
    printf '],\n'
    printf '  "passes": [\n'
    local n=${#PASS_NAMES[@]} i name manifest_json ptslog_json
    for ((i=0;i<n;i++)); do
      name="${PASS_NAMES[$i]}"
      if [ -n "${PASS_MANIFEST[$name]}" ]; then
        manifest_json="\"$(json_escape "$(basename "${PASS_MANIFEST[$name]}")")\""
      else
        manifest_json="null"
      fi
      if [ -n "${PASS_PTSLOG[$name]:-}" ]; then
        ptslog_json="\"$(json_escape "$(basename "${PASS_PTSLOG[$name]}")")\""
      else
        ptslog_json="null"
      fi
      printf '    {"name": "%s", "output": "%s", "manifest": %s, "pts_hooks_log": %s, "status": "%s"}' \
        "$(json_escape "$name")" \
        "$(json_escape "$(basename "${PASS_OUTFILE[$name]}")")" \
        "$manifest_json" \
        "$ptslog_json" \
        "${PASS_STATUS[$name]}"
      if [ "$i" -lt $((n-1)) ]; then printf ',\n'; else printf '\n'; fi
    done
    printf '  ]\n'
    printf '}\n'
  } > "$out"
}

while [ $# -gt 0 ]; do
  case "$1" in
    -o|--outdir)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      OUTDIR="$2"; shift 2 ;;
    -p|--prefix)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      PREFIX="$2"; shift 2 ;;
    -c|--config)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      CONFIG_FILE="$2"; shift 2 ;;
    --wspy)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      WSPY="$2"; shift 2 ;;
    --manifest-dir)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      MANIFEST_DIR="$2"; shift 2 ;;
    --run-index)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      RUN_INDEX="$2"; shift 2 ;;
    --suite)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      SUITE="$2"; shift 2 ;;
    --benchmark)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      BENCHMARK="$2"; shift 2 ;;
    --run-id)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      RUN_ID="$2"; shift 2 ;;
    --affinity)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      AFFINITY="$2"; shift 2 ;;
    --config-option)
      [ $# -ge 2 ] || { echo "$SCRIPT_NAME: $1 requires an argument" >&2; exit 1; }
      CONFIG_OPTIONS+=("$2"); shift 2 ;;
    --list)
      LIST_ONLY=1; shift ;;
    --dry-run)
      DRY_RUN=1; shift ;;
    -h|--help)
      usage; exit 0 ;;
    --)
      shift; WORKLOAD=("$@"); break ;;
    -*)
      echo "$SCRIPT_NAME: unknown option: $1" >&2
      usage >&2
      exit 1 ;;
    *)
      if [ -n "$PROFILE" ]; then
        echo "$SCRIPT_NAME: unexpected argument: $1 (profile already set to $PROFILE)" >&2
        exit 1
      fi
      PROFILE="$1"; shift ;;
  esac
done

if [ "$LIST_ONLY" -eq 1 ]; then
  list_profiles
  exit 0
fi

if [ -n "$CONFIG_FILE" ] && [ -n "$PROFILE" ]; then
  echo "$SCRIPT_NAME: specify a profile or --config, not both" >&2
  exit 1
fi
if [ -z "$CONFIG_FILE" ] && [ -z "$PROFILE" ]; then
  echo "$SCRIPT_NAME: missing profile or --config (try --list or --help)" >&2
  exit 1
fi
if [ ${#WORKLOAD[@]} -eq 0 ]; then
  echo "$SCRIPT_NAME: missing workload command after --" >&2
  exit 1
fi

if [ -n "$SUITE" ] || [ -n "$BENCHMARK" ]; then
  if [ -z "$SUITE" ] || [ -z "$BENCHMARK" ]; then
    echo "$SCRIPT_NAME: --suite and --benchmark must be given together" >&2
    exit 1
  fi
  UNIFIED=1
elif [ -n "$RUN_ID" ]; then
  echo "$SCRIPT_NAME: --run-id requires --suite and --benchmark" >&2
  exit 1
fi
if [ "$UNIFIED" -eq 1 ] && [ -n "$PREFIX" ]; then
  echo "$SCRIPT_NAME: --prefix cannot be combined with --suite/--benchmark (the run directory already namespaces output)" >&2
  exit 1
fi

if [ "$UNIFIED" -eq 1 ]; then
  # Sortable, unique-enough-per-host id, same shape as run_index.c's own
  # per-process run_id (<timestamp-ms>-<pid>) -- a distinct value here since
  # this identifies the whole wspy-run invocation, not one wspy process.
  # (Not "date +%3N": some date implementations, e.g. uutils coreutils,
  # ignore the field-width digit and print full nanoseconds instead of
  # truncating -- slice milliseconds out of %N by hand instead.)
  if [ -z "$RUN_ID" ]; then
    stamp="$(date -u +%Y%m%dT%H%M%S)"
    ns="$(date -u +%N)"
    RUN_ID="${stamp}.${ns:0:3}-$$"
  fi
  RUNROOT="${OUTDIR%/}/${SUITE}/${BENCHMARK}/${RUN_ID}"
  OUTDIR="$RUNROOT"
  PREFIX=""
  [ -n "$MANIFEST_DIR" ] || MANIFEST_DIR="$RUNROOT"
fi

if [ -n "$CONFIG_FILE" ]; then
  load_config_file "$CONFIG_FILE"
else
  load_profiles "$PROFILE"
fi

if [ "$DRY_RUN" -ne 1 ]; then
  mkdir -p "$OUTDIR"
  [ -n "$MANIFEST_DIR" ] && mkdir -p "$MANIFEST_DIR"
  [ "$UNIFIED" -eq 1 ] && mkdir -p "${RUNROOT}/plots"
  if [ ! -x "$WSPY" ]; then
    echo "$SCRIPT_NAME: wspy binary not found or not executable: $WSPY" >&2
    exit 1
  fi
fi

FAILED=0
for i in "${!PASS_NAMES[@]}"; do
  run_pass "${PASS_NAMES[$i]}" "${PASS_FLAGS[$i]}" "${PASS_TIMEOUTS[$i]}" || FAILED=1
done

if [ "$UNIFIED" -eq 1 ] && [ "$DRY_RUN" -ne 1 ]; then
  generate_summary
  generate_manifest
  echo "run directory: $RUNROOT" >&2
fi

exit "$FAILED"
